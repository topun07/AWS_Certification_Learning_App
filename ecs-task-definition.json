{
  "family": "knowledgeforge-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::774075997131:role/kf-ecs-execution",
  "taskRoleArn": "arn:aws:iam::774075997131:role/kf-ecs-task",
  "containerDefinitions": [
    {
      "name": "knowledgeforge-api",
      "image": "774075997131.dkr.ecr.us-east-1.amazonaws.com/knowledgeforge-api:latest",
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "prod" },
        { "name": "DATABASE_URL", "value": "jdbc:postgresql://knowledgeforge-db.cgzgia0ci4u8.us-east-1.rds.amazonaws.com:5432/knowledgeforge" },
        { "name": "DATABASE_USERNAME", "value": "kfadmin" },
        { "name": "DATABASE_PASSWORD", "value": "KnowledgeForge2026!" },
        { "name": "CORS_ORIGIN", "value": "https://knowledgeforgeacademy.com" }
      ],
      "secrets": [
        { "name": "JWT_SECRET", "valueFrom": "arn:aws:secretsmanager:us-east-1:774075997131:secret:knowledgeforge/jwt-secret-X4xIOH" },
        { "name": "STRIPE_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:774075997131:secret:knowledgeforge/stripe-api-key-FVL44Y" },
        { "name": "STRIPE_WEBHOOK_SECRET", "valueFrom": "arn:aws:secretsmanager:us-east-1:774075997131:secret:knowledgeforge/stripe-webhook-secret-WI0h3N" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/knowledgeforge-api",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8080/actuator/health || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 5,
        "startPeriod": 120
      }
      },
      { 
        "name": "SES_SMTP_USERNAME", "value": "AKIA3IOUGLPF7UDBGNOA " 
      },
      { 
        "name": "SES_SMTP_PASSWORD", "value": "BANQH+7EI80DZgQIQ8Az9JWkI857kTruTuDngpbg+6Z+" 
    }
    
  ]
}
